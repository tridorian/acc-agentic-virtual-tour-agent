# Required — GCP project hosting Vertex AI
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# ADK agent model
DEMO_AGENT_MODEL=gemini-live-2.5-flash-native-audio

# Weaviate
# Local dev: use localhost with kubectl port-forward
# Cloud Run: uses Cloud DNS private zone (weaviate.weaviate.internal:8080) — set in cloudbuild.yaml
WEAVIATE_ENDPOINT=http://localhost:8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=StarLearnersKB
# WEAVIATE_API_KEY=   # only needed if auth is enabled

# Embedding model — must match what was used during ingestion
GEMINI_EMBED_MODEL=gemini-embedding-2-preview
